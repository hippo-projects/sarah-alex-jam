{
  "name": "sarah-alex-jam",
  "version": "1.0.0",
  "description": "A music jam with Sarah and Alex.",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"yarn workspace sarah-alex-jam-client dev\" \"yarn workspace sarah-alex-jam-server dev\"",
    "dev:client": "yarn workspace sarah-alex-jam-client dev",
    "dev:server": "yarn workspace sarah-alex-jam-server dev",
    "seed": "npm run seed --workspace server"
    "cache:clear": "yarn cache clean && rm -rf client/node_modules server/node_modules node_modules && yarn install",
    "cache:clear:vite": "rm -rf client/node_modules/.vite"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hippo-projects/sarah-alex-jam.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/hippo-projects/sarah-alex-jam/issues"
  },
  "homepage": "https://github.com/hippo-projects/sarah-alex-jam#readme",
  "dependencies": {
    "yarn": "^1.22.22"
  }
}
